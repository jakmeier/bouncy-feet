  "query": "\n                    SELECT\n                        c.id,\n                        c.user_id,\n                        c.is_private,\n                        c.sort_order,\n                        c.free_form_category,\n                        c.title,\n                        c.video_short_uuid\n                    FROM clubs_combos cc\n                    JOIN combos c ON c.id = cc.combo_id\n                    WHERE club_id = $1\n                    AND cc.is_private\n                    ",
